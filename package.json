{
  "name": "aiftp-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "AI-first FTP/FTPS deploy tool — monorepo root",
  "license": "MIT",
  "author": "Tanaka Yuichiro <u16.tanaka@gmail.com>",
  "homepage": "https://github.com/aiftp-tools/aiftp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiftp-tools/aiftp.git"
  },
  "bugs": {
    "url": "https://github.com/aiftp-tools/aiftp/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": ["biome check --write --no-errors-on-unmatched"]
  }
}
