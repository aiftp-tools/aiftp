# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for shell scripts and config files
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary

# Lock files
pnpm-lock.yaml -diff merge=ours linguist-generated=true
