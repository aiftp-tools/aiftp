{
  "name": "@aiftp-tools/core",
  "version": "0.10.4",
  "description": "aiftp core engine: config, diff, deploy, backup, keychain",
  "license": "MIT",
  "author": "Tanaka Yuichiro <u16.tanaka@gmail.com>",
  "homepage": "https://github.com/aiftp-tools/aiftp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiftp-tools/aiftp.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/aiftp-tools/aiftp/issues"
  },
  "keywords": ["ftp", "ftps", "deploy", "ai", "aiftp"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "node scripts/generate-version.mjs",
    "pretypecheck": "node scripts/generate-version.mjs"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "basic-ftp": "^6.0.1",
    "fast-xml-parser": "^5.8.0",
    "iconv-lite": "0.7.2",
    "picomatch": "^4.0.4",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/iarna__toml": "^2.0.5",
    "@types/picomatch": "^4.0.3",
    "@types/ssh2-sftp-client": "^9.0.6",
    "ftp-srv": "^4.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
